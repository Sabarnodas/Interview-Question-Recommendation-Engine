# Choose an LLM provider. Copy the relevant lines into your shell before running.
#
# Recommended (FREE, no credit card): Google Gemini
#   Get a key: https://aistudio.google.com/app/apikey
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-key

# --- Alternatives ---
# Groq (FREE, fast):   https://console.groq.com/keys
# LLM_PROVIDER=groq
# GROQ_API_KEY=your-groq-key

# Ollama (FREE, local, offline — needs `ollama serve` running):
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1

# OpenAI (paid):
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Anthropic Claude (paid):
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model for any provider
# LLM_MODEL=gemini-2.0-flash
